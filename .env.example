# ============================================
# WhatsappErdBot — Environment Variables
# ============================================

# --- Application ---
NODE_ENV=production
LOG_LEVEL=info

# --- Database Paths ---
MAIN_DB_PATH=./data/database/main.db
PRODUCTS_DB_PATH=./data/database/products.db

# --- WhatsApp ---
WA_SESSION_PATH=./data/auth_info

# --- OpenCode AI ---
AI_PROVIDER=opencode-go
OPENCODE_GO_API_KEY=sk-your-key-here
AI_MODEL=deepseek-v4-pro
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.7
AI_TIMEOUT=30000
AI_MAX_RETRIES=3

# --- Backups ---
BACKUP_ENABLED=true
BACKUP_KEEP_DAYS=30

# ============================================
# WhatsappErdBot — Environment Variables
# ============================================

# --- Application ---
NODE_ENV=production
LOG_LEVEL=info
BAILEYS_LOG_LEVEL=silent

# --- Database Paths ---
MAIN_DB_PATH=./data/database/main.db
PRODUCTS_DB_PATH=./data/database/products.db

# --- WhatsApp ---
WA_SESSION_PATH=./data/auth_info
WA_MAX_RECONNECT=10

# --- OpenCode AI ---
AI_PROVIDER=opencode-go
AI_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_API_KEY=sk-your-key-here
AI_MODEL=qwen3.5-plus
AI_MAX_TOKENS=800
AI_TEMPERATURE=0.7
AI_TIMEOUT=30000
AI_MAX_RETRIES=3

# --- Backups ---
BACKUP_ENABLED=true
BACKUP_KEEP_DAYS=30
